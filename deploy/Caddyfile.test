# Phase B test — HTTPS on :8456 only, localhost internal cert. Same-origin /api -> backend.
{
	auto_https disable_redirects
}

localhost:8456 {
	encode gzip
	tls internal

	handle_path /api/* {
		reverse_proxy backend:8000
	}
	handle /docs* {
		reverse_proxy backend:8000
	}
	handle /openapi.json {
		reverse_proxy backend:8000
	}
	handle {
		reverse_proxy frontend:3000
	}
}
